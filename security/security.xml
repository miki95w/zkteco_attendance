<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Module Category -->
        <record id="module_category_zkteco" model="ir.module.category">
            <field name="name">ZKTeco Attendance</field>
            <field name="description">Helps you manage ZKTeco biometric devices and attendance records.</field>
            <field name="sequence">15</field>
        </record>

        <!-- Groups -->
        <record id="group_zkteco_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_zkteco"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_zkteco_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_zkteco"/>
            <field name="implied_ids" eval="[(4, ref('group_zkteco_user'))]"/>
        </record>

        <record id="group_zkteco_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_zkteco"/>
            <field name="implied_ids" eval="[(4, ref('group_zkteco_manager'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Record Rules: zkteco.attendance.record -->
        <record id="rule_zkteco_record_user" model="ir.rule">
            <field name="name">ZKTeco Record User</field>
            <field name="model_id" ref="model_zkteco_attendance_record"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_zkteco_user'))]"/>
        </record>

        <record id="rule_zkteco_record_manager" model="ir.rule">
            <field name="name">ZKTeco Record Manager</field>
            <field name="model_id" ref="model_zkteco_attendance_record"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_zkteco_manager')), (4, ref('group_zkteco_admin'))]"/>
        </record>

        <!-- Record Rules: zkteco.attendance (Punches) -->
        <record id="rule_zkteco_attendance_user" model="ir.rule">
            <field name="name">ZKTeco Attendance User</field>
            <field name="model_id" ref="model_zkteco_attendance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_zkteco_user'))]"/>
        </record>

        <record id="rule_zkteco_attendance_manager" model="ir.rule">
            <field name="name">ZKTeco Attendance Manager</field>
            <field name="model_id" ref="model_zkteco_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_zkteco_manager')), (4, ref('group_zkteco_admin'))]"/>
        </record>
    </data>
</odoo>
