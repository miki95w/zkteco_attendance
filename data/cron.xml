<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Process ZKTeco Attendance Logs -->
        <record id="ir_cron_process_zkteco_attendance" model="ir.cron">
            <field name="name">Process ZKTeco Attendance Logs</field>
            <field name="model_id" ref="model_zkteco_attendance"/>
            <field name="state">code</field>
            <field name="code">model.action_process_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
        
        <!-- Generate Daily Attendance Records -->
        <record id="ir_cron_generate_daily_attendance" model="ir.cron">
            <field name="name">Generate Daily Attendance Records</field>
            <field name="model_id" ref="model_zkteco_attendance_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_daily_records()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
        
        <!-- Auto-Mark Absent Employees -->
        <record id="ir_cron_auto_mark_absent" model="ir.cron">
            <field name="name">Auto-Mark Absent Employees</field>
            <field name="model_id" ref="model_zkteco_attendance_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_mark_absent()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
        
        <!-- Sync Cloud Data -->
        <record id="ir_cron_sync_cloud_data" model="ir.cron">
            <field name="name">Sync ZKTeco Cloud Data</field>
            <field name="model_id" ref="model_zkteco_cloud_config"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_cloud_data()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
        
        <!-- Sync ADMS Data -->
        <record id="ir_cron_sync_adms_data" model="ir.cron">
            <field name="name">Sync Flask ADMS Data</field>
            <field name="model_id" ref="model_zkteco_adms_config"/>
            <field name="state">code</field>
            <field name="code">model.cron_fetch_attendance_data()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>