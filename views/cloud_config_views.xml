<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cloud Configuration Form View -->
    <record id="view_cloud_config_form" model="ir.ui.view">
        <field name="name">zkteco.cloud.config.form</field>
        <field name="model">zkteco.cloud.config</field>
        <field name="arch" type="xml">
            <form string="ZKTeco Cloud Configuration">
                <header>
                    <button name="action_test_connection" string="Test Connection" 
                            type="object" class="oe_highlight" icon="fa-plug"/>
                    <button name="action_fetch_attendance_data" string="Sync Now" 
                            type="object" class="btn-primary" icon="fa-refresh"/>
                    <field name="connection_status" widget="badge" 
                           decoration-success="connection_status == 'connected'"
                           decoration-danger="connection_status == 'error'"
                           decoration-warning="connection_status == 'disconnected'"/>
                </header>
                <sheet>
                    <field name="active" widget="boolean_toggle"/>
                    
                    <group>
                        <group string="Basic Configuration">
                            <field name="name"/>
                            <field name="cloud_server_url" placeholder="http://cloud-server-ip:port"/>
                            <field name="api_endpoint" placeholder="/api/attendance"/>
                        </group>
                        <group string="Status">
                            <field name="last_sync" readonly="1"/>
                            <field name="auto_sync_enabled"/>
                            <field name="sync_interval"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Authentication">
                            <group>
                                <field name="auth_type"/>
                                <field name="username" invisible="auth_type != 'basic'"/>
                                <field name="password" password="True" invisible="auth_type != 'basic'"/>
                                <field name="api_token" password="True" invisible="auth_type != 'token'"/>
                                <field name="custom_headers" widget="text" invisible="auth_type != 'custom'"
                                       placeholder='{"Authorization": "Bearer YOUR_TOKEN", "X-API-Key": "YOUR_KEY"}'/>
                            </group>
                        </page>
                        
                        <page string="Data Mapping">
                            <group string="Field Mapping">
                                <p>Configure how to map fields from your cloud server's JSON response:</p>
                            </group>
                            <group>
                                <group>
                                    <field name="device_id_field" placeholder="device_id"/>
                                    <field name="user_id_field" placeholder="user_id"/>
                                </group>
                                <group>
                                    <field name="timestamp_field" placeholder="timestamp"/>
                                    <field name="event_type_field" placeholder="event_type"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Error Log">
                            <field name="last_error" widget="text" readonly="1" 
                                   invisible="not last_error"/>
                            <div invisible="last_error" class="alert alert-success">
                                <strong>No errors recorded</strong>
                            </div>
                        </page>
                        
                        <page string="Help">
                            <group>
                                <div class="alert alert-info" role="alert">
                                    <h4>Cloud Server Integration Setup</h4>
                                    <p><strong>Step 1:</strong> Enter your cloud server URL and port</p>
                                    <p><strong>Step 2:</strong> Configure authentication (API key, username/password, etc.)</p>
                                    <p><strong>Step 3:</strong> Set the API endpoint path (e.g., /api/attendance)</p>
                                    <p><strong>Step 4:</strong> Test the connection</p>
                                    <p><strong>Step 5:</strong> Configure field mapping if needed</p>
                                    <p><strong>Step 6:</strong> Enable auto sync</p>
                                    
                                    <hr/>
                                    <h5>Common Cloud Server Formats:</h5>
                                    <ul>
                                        <li><strong>ZKTeco Cloud:</strong> Usually requires API key authentication</li>
                                        <li><strong>Custom API:</strong> May use token or basic auth</li>
                                        <li><strong>Third-party:</strong> Check documentation for format</li>
                                    </ul>
                                    
                                    <h5>Example JSON Response:</h5>
                                    <code>
                                    {
                                      "data": [
                                        {
                                          "device_id": "123456",
                                          "user_id": "1001", 
                                          "timestamp": "2024-01-15 09:00:00",
                                          "event_type": 1
                                        }
                                      ]
                                    }
                                    </code>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Cloud Configuration Tree View -->
    <record id="view_cloud_config_tree" model="ir.ui.view">
        <field name="name">zkteco.cloud.config.tree</field>
        <field name="model">zkteco.cloud.config</field>
        <field name="arch" type="xml">
            <tree string="Cloud Configurations">
                <field name="name"/>
                <field name="cloud_server_url"/>
                <field name="connection_status" widget="badge" 
                       decoration-success="connection_status == 'connected'"
                       decoration-danger="connection_status == 'error'"
                       decoration-warning="connection_status == 'disconnected'"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="last_sync"/>
                <button name="action_test_connection" string="Test" type="object" 
                        icon="fa-plug" class="btn-link"/>
                <button name="action_fetch_attendance_data" string="Sync" type="object" 
                        icon="fa-refresh" class="btn-link"/>
            </tree>
        </field>
    </record>

    <!-- Cloud Configuration Action -->
    <record id="action_cloud_config" model="ir.actions.act_window">
        <field name="name">Cloud Server Config</field>
        <field name="res_model">zkteco.cloud.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure Cloud Server Connection
            </p>
            <p>
                Connect to your ZKTeco cloud server to automatically sync attendance data.
                Enter your cloud server URL, authentication details, and test the connection.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_cloud_config"
              name="Cloud Server Config"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_cloud_config"
              sequence="90"/>

</odoo>