<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Attendance Dashboard Form View -->
    <record id="view_attendance_dashboard_form" model="ir.ui.view">
        <field name="name">zkteco.attendance.dashboard.form</field>
        <field name="model">zkteco.attendance.dashboard</field>
        <field name="arch" type="xml">
            <form string="Attendance Dashboard" create="false" delete="false">
                <header>
                    <button name="action_refresh_dashboard" string="Refresh" type="object" class="oe_highlight" icon="fa-refresh"/>
                    <button name="action_view_detailed_attendance" string="Detailed Records" type="object" class="btn-primary" icon="fa-list"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <p>Real-time attendance overview for today</p>
                    </div>
                    
                    <!-- Today's Statistics -->
                    <group string="Today's Attendance Summary">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="card text-center border-success">
                                    <div class="card-body">
                                        <button name="action_view_present_today" type="object" class="btn btn-link p-0">
                                            <h3 class="text-success">
                                                <field name="present_today" widget="integer"/>
                                            </h3>
                                            <p class="text-success">Present</p>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center border-danger">
                                    <div class="card-body">
                                        <button name="action_view_absent_today" type="object" class="btn btn-link p-0">
                                            <h3 class="text-danger">
                                                <field name="absent_today" widget="integer"/>
                                            </h3>
                                            <p class="text-danger">Absent</p>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center border-warning">
                                    <div class="card-body">
                                        <button name="action_view_missed_punch_today" type="object" class="btn btn-link p-0">
                                            <h3 class="text-warning">
                                                <field name="missed_punch_today" widget="integer"/>
                                            </h3>
                                            <p class="text-warning">Missed Punch</p>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center border-info">
                                    <div class="card-body">
                                        <h3 class="text-info">
                                            <field name="on_leave_today" widget="integer"/>
                                        </h3>
                                        <p class="text-info">On Leave</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </group>
                    
                    <group string="Punctuality Today">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="card text-center border-warning">
                                    <div class="card-body">
                                        <button name="action_view_late_arrivals_today" type="object" class="btn btn-link p-0">
                                            <h4 class="text-warning">
                                                <field name="late_arrivals_today" widget="integer"/>
                                            </h4>
                                            <p class="text-warning">Late Arrivals</p>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card text-center border-secondary">
                                    <div class="card-body">
                                        <h4 class="text-secondary">
                                            <field name="early_leaves_today" widget="integer"/>
                                        </h4>
                                        <p class="text-secondary">Early Leaves</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </group>
                    
                    <!-- Overall Statistics -->
                    <group string="Overall Statistics">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h4>
                                            <field name="total_employees" widget="integer"/>
                                        </h4>
                                        <p>Total Employees</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h4>
                                            <field name="online_devices" widget="integer"/> / 
                                            <field name="total_devices" widget="integer"/>
                                        </h4>
                                        <p>Devices Online</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h4>
                                            <field name="attendance_this_month" widget="percentage"/>
                                        </h4>
                                        <p>Monthly Attendance</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </group>
                    
                    <!-- Quick Actions -->
                    <group string="Quick Actions">
                        <div class="row">
                            <div class="col-md-12">
                                <button name="action_view_detailed_attendance" string="View All Attendance Records" 
                                        type="object" class="btn btn-primary btn-lg btn-block" icon="fa-table"/>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <button name="%(action_attendance_today_present)d" string="Present Today Details" 
                                        type="action" class="btn btn-success btn-block" icon="fa-check"/>
                            </div>
                            <div class="col-md-6">
                                <button name="%(action_attendance_today_absent)d" string="Absent Today Details" 
                                        type="action" class="btn btn-danger btn-block" icon="fa-times"/>
                            </div>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Simplified Dashboard Kanban View -->
    <record id="view_attendance_dashboard_kanban" model="ir.ui.view">
        <field name="name">zkteco.attendance.dashboard.kanban</field>
        <field name="model">zkteco.attendance.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard" create="false" delete="false">
                <field name="present_today"/>
                <field name="absent_today"/>
                <field name="missed_punch_today"/>
                <field name="on_leave_today"/>
                <field name="total_employees"/>
                <field name="late_arrivals_today"/>
                <field name="early_leaves_today"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">Attendance Dashboard</div>
                                    <div class="text-muted">Today's Overview</div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button type="object" name="action_view_present_today" class="btn btn-primary">
                                            <span class="o_value"><t t-esc="record.present_today.value"/></span>
                                            <span class="o_label">Present</span>
                                        </button>
                                    </div>
                                    <div class="col-6 o_kanban_primary_right">
                                        <button type="object" name="action_view_absent_today" class="btn btn-secondary">
                                            <span class="o_value"><t t-esc="record.absent_today.value"/></span>
                                            <span class="o_label">Absent</span>
                                        </button>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <button type="object" name="action_view_missed_punch_today" class="btn btn-warning btn-sm">
                                            <t t-esc="record.missed_punch_today.value"/> Missed Punch
                                        </button>
                                    </div>
                                    <div class="col-6">
                                        <span class="badge badge-info">
                                            <t t-esc="record.on_leave_today.value"/> On Leave
                                        </span>
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-12">
                                        <button type="object" name="action_view_detailed_attendance" class="btn btn-outline-primary btn-sm btn-block">
                                            View All Records
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_attendance_dashboard" model="ir.actions.act_window">
        <field name="name">Attendance Dashboard</field>
        <field name="res_model">zkteco.attendance.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_attendance_dashboard_form"/>
        <field name="res_id" ref="default_attendance_dashboard"/>
        <field name="target">current</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Attendance Dashboard
            </p>
            <p>
                Get a complete overview of today's attendance, including present, absent, 
                and missed punch employees at a glance.
            </p>
        </field>
    </record>

    <!-- Dashboard Menu (Top Level) -->
    <menuitem id="menu_attendance_dashboard"
              name="Attendance Records"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_attendance_dashboard"
              sequence="1"/>
              
    <!-- Submenu for detailed records under the dashboard -->
    <menuitem id="menu_detailed_attendance_records"
              name="Detailed Records"
              parent="menu_attendance_dashboard"
              action="action_detailed_attendance_report"
              sequence="10"/>

</odoo>