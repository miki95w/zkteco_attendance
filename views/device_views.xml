<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zkteco_device_tree" model="ir.ui.view">
        <field name="name">zkteco.device.tree</field>
        <field name="model">zkteco.device</field>
        <field name="arch" type="xml">
            <tree decoration-success="online_status == 'online'" decoration-muted="online_status == 'offline'">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="ip_address"/>
                <field name="last_sync"/>
                <field name="online_status" widget="badge"
                    decoration-success="online_status == 'online'"
                    decoration-danger="online_status == 'offline'"/>
            </tree>
        </field>
    </record>

    <record id="view_zkteco_device_form" model="ir.ui.view">
        <field name="name">zkteco.device.form</field>
        <field name="model">zkteco.device</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_fetch_users"
                            string="Get Users"
                            type="object"
                            class="oe_highlight"
                            icon="fa-users"/>
                    <button name="action_fetch_logs"
                            string="Fetch Logs"
                            type="object"
                            icon="fa-clock-o"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                icon="fa-users"
                                type="object"
                                name="action_open_users">
                            <field name="user_count" widget="statinfo" string="Users"/>
                        </button>
                        <button class="oe_stat_button"
                                icon="fa-clock-o"
                                type="object"
                                name="action_open_attendance">
                            <field name="attendance_log_count" widget="statinfo" string="Punches"/>
                        </button>
                    </div>

                    <!-- ── Title ─────────────────────────────────── -->
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Device Name"/></h1>
                    </div>

                    <!-- ── Info Fields ───────────────────────────── -->
                    <group>
                        <group>
                            <field name="serial_number"/>
                            <field name="ip_address"/>
                        </group>
                        <group>
                            <field name="last_sync" readonly="1"/>
                            <field name="online_status" widget="badge"
                                decoration-success="online_status == 'online'"
                                decoration-danger="online_status == 'offline'"/>
                        </group>
                    </group>

                    <!-- ── Tabs ──────────────────────────────────── -->
                    <notebook>
                        <!-- ── Device Users Tab ─────────────────── -->
                        <page string="Device Users" name="device_users">
                            <div class="o_field_widget" style="margin-bottom:8px;">
                                <button name="action_fetch_users"
                                        string="Get Users from Device"
                                        type="object"
                                        class="btn btn-primary"
                                        icon="fa-download"
                                        help="Pull the latest enrolled user list from the physical device"/>
                            </div>
                            <field name="user_mapping_ids"
                                   nolabel="1">
                                <tree editable="bottom"
                                      decoration-success="employee_id != False"
                                      decoration-muted="employee_id == False">
                                    <field name="device_user_id" string="Device ID" readonly="1"/>
                                    <field name="device_user_name" string="Name" readonly="1"/>
                                    <field name="employee_id"
                                           string="Linked Employee"
                                           options="{'no_create': True}"
                                           placeholder="— select employee —"/>
                                    <field name="last_punch" string="Last Punch" readonly="1"/>
                                    <field name="attendance_count" string="Total Punches" readonly="1"/>
                                    <button name="action_view_attendance"
                                            type="object"
                                            string="Logs"
                                            icon="fa-list"
                                            class="btn btn-sm btn-link"
                                            help="View raw attendance log for this user"/>
                                    <button name="action_view_hr_attendance"
                                            type="object"
                                            string="HR"
                                            icon="fa-calendar"
                                            class="btn btn-sm btn-link"
                                            invisible="employee_id == False"
                                            help="View HR attendance for the linked employee"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         ACTIONS
         ═══════════════════════════════════════════════════ -->
    <record id="action_zkteco_device" model="ir.actions.act_window">
        <field name="name">ZKTeco Devices</field>
        <field name="res_model">zkteco.device</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         MENUS
         ═══════════════════════════════════════════════════ -->
    <menuitem id="menu_zkteco_root" name="ZKTeco" sequence="10" web_icon="fa-fingerprint,#4C5B85,#ffffff" groups="zkteco_attendance.group_zkteco_user"/>
    <menuitem id="menu_zkteco_configuration" name="Configuration" parent="menu_zkteco_root" sequence="100" groups="zkteco_attendance.group_zkteco_admin"/>
    <menuitem id="menu_zkteco_device" name="Devices" parent="menu_zkteco_configuration" action="action_zkteco_device" sequence="10" groups="zkteco_attendance.group_zkteco_admin"/>
</odoo>
